# Copy to .env and fill in values for local development

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=odoo
DB_NAME=<your-client-slug>

# Odoo
ADMIN_PASSWD=admin
ODOO_DEV_MODE=true
ODOO_WORKERS=0
ODOO_LOG_LEVEL=info
ODOO_MAX_CRON_THREADS=1
ODOO_DB_MAXCONN=10
ODOO_LIMIT_TIME_REAL=600
ODOO_LIMIT_TIME_CPU=300
ODOO_QUEUE_JOB_CHANNELS=root:1
SKIP_MODULE_SETUP=false

# Server
SERVER_URL=http://localhost:8069
META_BASE_API_URL=
AGENTIC_BASE_URL=

# API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
NOMIC_API_KEY=

# Contact defaults
DEFAULT_ADMIN_PHONE=
DEFAULT_COMPANY_EMAIL=
DEFAULT_COMPANY_PHONE=
